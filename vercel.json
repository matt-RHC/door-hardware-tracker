{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/sync-smartsheet",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "src/app/api/parse-pdf/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/parse-pdf/chunk/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/parse-pdf/save/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/parse-pdf/compare/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/parse-pdf/apply-revision/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/projects/[projectId]/sync-smartsheet/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/sync-smartsheet/route.ts": {
      "maxDuration": 300
    },
    "api/extract-tables.py": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/classify-pages.py": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/detect-mapping.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
