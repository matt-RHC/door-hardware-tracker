{
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/cleanup-staging",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/process-jobs",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/reap-stuck-runs",
      "schedule": "*/30 * * * *"
    }
  ],
  "functions": {
    "src/app/api/parse-pdf/route.ts": {
      "maxDuration": 800
    },
    "src/app/api/parse-pdf/chunk/route.ts": {
      "maxDuration": 800
    },
    "src/app/api/parse-pdf/triage/route.ts": {
      "maxDuration": 800
    },
    "src/app/api/parse-pdf/save/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/parse-pdf/compare/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/parse-pdf/apply-revision/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/parse-pdf/region-extract/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/parse-pdf/classify-pages/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/parse-pdf/detect-mapping/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/parse-pdf/deep-extract/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/parse-pdf/vision-extract/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/jobs/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/jobs/[id]/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/jobs/[id]/run/route.ts": {
      "maxDuration": 800
    },
    "src/app/api/jobs/[id]/results/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/jobs/[id]/answers/route.ts": {
      "maxDuration": 10
    },
    "src/app/api/cron/process-jobs/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/cron/reap-stuck-runs/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/projects/[projectId]/punch-notes/export-pdf/route.ts": {
      "maxDuration": 60
    },
    "api/extract-tables.py": {
      "maxDuration": 800,
      "memory": 3008
    },
    "api/classify-pages.py": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/detect-mapping.py": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
