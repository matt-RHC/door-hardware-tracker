# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API (for PDF parsing)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Staging flow (defaults to true; set to "false" to disable)
USE_STAGING_FLOW=true

# App URL (for QR codes)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Shared secret used to authenticate Next.js -> Python endpoint calls.
# The Next.js layer sends this as X-Internal-Token; the Python handlers
# verify it before accepting a PDF. Generate with:
#   openssl rand -hex 32
# If unset, the Python endpoints log a warning and accept all requests
# (supports a zero-downtime rollout). Once configured in Vercel, the
# secret is enforced on the next cold start.
PYTHON_INTERNAL_SECRET=

# Sentry error monitoring
# DSN is public (safe for client bundle). Get from sentry.io → Project Settings → DSN.
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@o12345.ingest.us.sentry.io/12345
# Auth token for source map uploads (optional, improves stack traces).
# Get from sentry.io → Settings → Auth Tokens. Set in Vercel env vars only.
# SENTRY_AUTH_TOKEN=
